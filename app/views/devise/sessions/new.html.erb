<%# app/views/devise/sessions/new.html.erb %>
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      <div class="ksn-card p-4 p-md-5">

        <%# Header %>
        <div class="text-center mb-4">
          <div class="ksn-badge-icon mx-auto mb-3" style="width:52px;height:52px;border-radius:18px;font-size:26px;">
            <span class="material-symbols-outlined">lock_open</span>
          </div>
          <h2 class="fw-bold mb-1">Welcome Back</h2>
          <p class="ksn-muted">Log in to continue your learning journey</p>
        </div>

        <%# Login form %>
        <div class="ksn-form">
          <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
            <div class="form-inputs mb-3">
              <%= f.input :email,
                          required: false,
                          autofocus: true,
                          input_html: { autocomplete: "email", class: "form-control-lg" },
                          wrapper_html: { class: "mb-3" } %>

              <%= f.input :password,
                          required: false,
                          input_html: { autocomplete: "current-password", class: "form-control-lg" },
                          wrapper_html: { class: "mb-3" } %>

              <%= f.input :remember_me, as: :boolean, wrapper_html: { class: "mb-2" } if devise_mapping.rememberable? %>
            </div>

            <div class="form-actions d-grid gap-2">
              <%= f.button :submit, "Log in", class: "btn ksn-btn-primary btn-lg fw-bold" %>
            </div>
          <% end %>
        </div>

        <%# Footer links %>
        <div class="text-center mt-4 pt-3" style="border-top: 1px solid var(--ksn-border);">
          <p class="mb-1 ksn-muted">Don't have an account?</p>
          <%= link_to "Sign up", new_registration_path(resource_name), class: "ksn-auth-link" %>
        </div>

      </div>
    </div>
  </div>
</div>
