
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body p-4 p-md-5">
          <div class="text-center mb-4">
            <h2 class="fw-bold mb-1">Welcome Back</h2>
            <p class="text-muted">Log in to continue your learning journey</p>
          </div>

          <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
            <div class="form-inputs mb-3">
              <%= f.input :email,
                          required: false,
                          autofocus: true,
                          input_html: { autocomplete: "email", class: "form-control-lg" },
                          wrapper_html: { class: "mb-3" } %>

              <%= f.input :password,
                          required: false,
                          input_html: { autocomplete: "current-password", class: "form-control-lg" },
                          wrapper_html: { class: "mb-3" } %>

              <%= f.input :remember_me, as: :boolean, wrapper_html: { class: "mb-2" } if devise_mapping.rememberable? %>
            </div>

            <div class="form-actions d-grid gap-2">
              <%= f.button :submit, "Log in", class: "btn btn-primary btn-lg fw-bold" %>
            </div>
          <% end %>

          <div class="text-center mt-4 pt-3 border-top">
            <p class="mb-0 text-muted">Don't have an account?</p>
            <%= link_to "Sign up", new_registration_path(resource_name), class: "text-decoration-none fw-bold" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
