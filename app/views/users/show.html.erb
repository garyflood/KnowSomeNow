<%# app/views/users/show.html.erb %>
<div class="container-xl py-5">

  <%# ── Add New Device Form ── %>
  <div class="row justify-content-center mb-5">
    <div class="col-12 col-md-8 col-lg-6">
      <div class="ksn-card p-4 p-md-5">
        <div class="ksn-eyebrow mb-3">AI-Powered Instructions</div>
        <h3 class="fw-bold mb-1">Add New Device</h3>
        <p class="ksn-muted mb-4">Type any device name and get instant step-by-step guidance.</p>

        <div class="ksn-form">
          <%= simple_form_for Device.new, url: devices_path do |f| %>
            <div class="form-inputs mb-3">
              <%= f.input :name,
                          label: "What device do you need help with?",
                          placeholder: "e.g. Nespresso machine, iPhone 15, Microwave...",
                          wrapper_html: { class: "mb-3" } %>
            </div>
            <div class="form-actions">
              <%= f.button :submit, "Get AI Instructions", class: "btn ksn-btn-primary w-100 fw-bold py-2" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# ── My Saved Instructions Grid ── %>
  <div class="d-flex align-items-center gap-2 mb-4">
    <h3 class="fw-bold mb-0">My Saved Instructions</h3>
    <span class="badge rounded-pill px-3 py-2" style="background: rgba(0,229,255,0.12); color: var(--ksn-primary); border: 1px solid rgba(0,229,255,0.22); font-size:.85rem;">
      <%= @user.devices.count %>
    </span>
  </div>

  <% if @user.devices.any? %>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
      <%= render partial: "devices/device", collection: @user.devices.order(created_at: :desc) %>
    </div>
  <% else %>
    <%# Empty state %>
    <div class="ksn-card text-center py-5 px-4">
      <div class="ksn-feature-icon mx-auto mb-3">
        <span class="material-symbols-outlined">devices</span>
      </div>
      <p class="ksn-muted mb-0">You haven't added any devices yet. Type one above!</p>
    </div>
  <% end %>

</div>
