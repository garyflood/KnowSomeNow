          </div>
          <div class="ksn-device-card" style="cursor:pointer;" data-action="click->quick-add#fill" data-quick-add-name-param="Apple Watch">
            <div class="ksn-device-icon ksn-device-icon-slate"><span class="material-symbols-outlined">watch</span></div>
            <div><div class="ksn-device-title">Apple Watch</div><div class="ksn-device-sub">watchOS Tips</div></div>
          </div>
          <div class="ksn-device-card" style="cursor:pointer;" data-action="click->quick-add#fill" data-quick-add-name-param="Nespresso Machine">
            <div class="ksn-device-icon ksn-device-icon-orange"><span class="material-symbols-outlined">coffee_maker</span></div>
            <div><div class="ksn-device-title">Nespresso</div><div class="ksn-device-sub">Coffee Machine</div></div>
          </div>
          <div class="ksn-device-card" style="cursor:pointer;" data-action="click->quick-add#fill" data-quick-add-name-param="Nest Thermostat">
            <div class="ksn-device-icon ksn-device-icon-primary"><span class="material-symbols-outlined">nest_thermostat</span></div>
            <div><div class="ksn-device-title">Thermostat</div><div class="ksn-device-sub">Nest & Ecobee</div></div>
          </div>
          <div class="ksn-device-card" style="cursor:pointer;" data-action="click->quick-add#fill" data-quick-add-name-param="DSLR Camera">
            <div class="ksn-device-icon ksn-device-icon-green"><span class="material-symbols-outlined">camera</span></div>
            <div><div class="ksn-device-title">Camera</div><div class="ksn-device-sub">DSLR & Mirrorless</div></div>
          </div>

      </div>
    </div>
  </div>
  <%# ── end marquee ── %>

  <!-- My Saved Instructions Grid -->
  <h3 class="mb-4">My Saved Instructions</h3>
  <% if @user.devices.any? %>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
      <%= render partial: "devices/device", collection: @user.devices.order(created_at: :desc) %>
    </div>
  <% else %>
    <%# Empty state %>
    <div class="ksn-card text-center py-5 px-4">
      <div class="ksn-feature-icon mx-auto mb-3">
        <span class="material-symbols-outlined">devices</span>
      </div>
      <p class="ksn-muted mb-0">You haven't added any devices yet. Type one above!</p>
    </div>
  <% end %>

</div>
