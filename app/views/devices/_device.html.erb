<%# app/views/devices/_device.html.erb %>
<div class="col">
  <div class="ksn-saved-card h-100">

    <%# ── Device image (Cloudinary URL stored in device.image) ── %>
    <% if device.image.present? %>
      <%= image_tag device.image, class: "card-img-top", style: "height: 160px; object-fit: cover;" %>
    <% else %>
      <div class="ksn-img-placeholder d-flex align-items-center justify-content-center" style="height: 160px;">
        <span class="material-symbols-outlined" style="font-size: 56px; color: var(--ksn-muted);">devices</span>
      </div>
    <% end %>

    <div class="card-body d-flex flex-column p-4">
      <h5 class="card-title fw-bold mb-1"><%= device.name %></h5>
      <small class="text-muted mb-2">Added <%= time_ago_in_words(device.created_at) %> ago</small>

      <p class="card-text small flex-grow-1">
        <% if device.instruction %>
          <%= truncate(strip_tags(markdown(device.instruction.steps)), length: 120) %>
        <% else %>
          No instructions generated yet.
        <% end %>
      </p>

      <%= link_to "Read more", device_path(device), class: "btn ksn-btn-primary btn-sm mt-3 align-self-start" %>
    </div>

  </div>
</div>
