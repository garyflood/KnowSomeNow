<%# app/views/devices/_device.html.erb %>
<div class="card mb-4 shadow-sm border-0">
  <div class="card-header bg-white border-bottom-0 pt-3">
    <h4 class="text-primary mb-0">
      <%= link_to device.name, device_path(device), class: "text-decoration-none text-primary" %>
    </h4>
    <small class="text-muted">Added <%= time_ago_in_words(device.created_at) %> ago</small>
  </div>

  <div class="card-body">
    <% if device.instruction %>
      <div class="instruction-content p-3 bg-light rounded border-start border-4 border-primary">
        <%= markdown(device.instruction.steps) %>
      </div>
    <% else %>
      <p class="text-muted italic">No instructions generated yet.</p>
    <% end %>
  </div>
</div>
